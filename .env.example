# OKX Onchain OS Web3 API credentials (required for live X Layer chain data)
# Dev portal: https://web3.okx.com/build/dev-portal (Connect Wallet, create project, create API key with passphrase)
# Auth: OK-ACCESS-KEY, OK-ACCESS-SIGN (HMAC-SHA256 base64), OK-ACCESS-TIMESTAMP, OK-ACCESS-PASSPHRASE
# Docs: https://web3.okx.com/onchainos/dev-docs/home/api-access-and-usage
# Legacy OKLINK_API_KEY / OKLINK_SECRET_KEY / OKLINK_PASSPHRASE names are read as fallbacks.
OKXOS_API_KEY=
OKXOS_SECRET_KEY=
OKXOS_PASSPHRASE=

# DEMO_MODE=true bypasses x402 on paid routes (local only).
# Production paid ASP: set DEMO_MODE=false (or unset). Playground uses /api/playground/scan (free, rate limited).
DEMO_MODE=true

# OKX SA API credentials for x402 facilitator (required when DEMO_MODE is off)
# Docs: https://github.com/okx/payments/blob/master/typescript/SELLER.md
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Seller payee wallet on X Layer (eip155:196). Receives USDT0 per paid call.
# Primary name used by this app. PAY_TO is accepted as an alias (SELLER.md).
X402_PAYTO_ADDRESS=
PAY_TO=

# Optional: OKX facilitator base URL (default https://web3.okx.com)
OKX_FACILITATOR_BASE_URL=

# Public site URL (OG tags, llms.txt, origin checks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Foreman dispatch: operational float wallet (BUYER side of x402).
# Private key of Foreman's OWN wallet that pays hired ASPs in USDT0 on X Layer.
# Never a caller wallet; callers only ever pay the fixed inbound fee.
# Funding, sizing, and rotation steps: RUNBOOK.md "Float wallet" section.
FOREMAN_FLOAT_PRIVATE_KEY=

# FOREMAN_DRY_RUN=true mocks all OUTBOUND hires (no payment, no network).
# Independent of DEMO_MODE, which bypasses the INBOUND payment gate only.
# Local dev: set both true. Production: set neither.
FOREMAN_DRY_RUN=true

# Spend caps in USDT0 (plain decimals, max 6 decimal places). Safe defaults shown.
# Any breach aborts the job cleanly; Foreman never silently exceeds a cap.
MAX_SPEND_PER_SUBCALL=0.10
MAX_SPEND_PER_JOB=0.35
MAX_SPEND_PER_DAY=5.00

# Timeout per downstream subcall in milliseconds (default 20000)
FOREMAN_SUBCALL_TIMEOUT_MS=

# X Layer RPC for the buyer signer (default https://rpc.xlayer.tech)
XLAYER_RPC_URL=

# scripts/paid-dispatch.ts only: the BUYER wallet that pays Foreman's inbound
# 0.50 USDT0 fee, exactly as any calling agent would. This is a caller wallet,
# NOT Foreman's float, and it is never read by the app or by any route.
# Required only when running that script with --confirm.
BUYER_PRIVATE_KEY=

# Endpoint the paid-dispatch script targets (default https://agentdnas.vercel.app/api/dispatch)
DISPATCH_URL=

# TEMPORARY. Enables the diagnostic route /api/diag/facilitator, which is a 404
# while this is unset. Set to a long random string during diagnosis only, then
# delete app/api/diag/ and remove this variable.
DIAG_TOKEN=
