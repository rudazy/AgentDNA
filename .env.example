# OKX Onchain OS Web3 API credentials (required for live X Layer chain data)
# Dev portal: https://web3.okx.com/build/dev-portal (Connect Wallet, create project, create API key with passphrase)
# Auth: OK-ACCESS-KEY, OK-ACCESS-SIGN (HMAC-SHA256 base64), OK-ACCESS-TIMESTAMP, OK-ACCESS-PASSPHRASE
# Docs: https://web3.okx.com/onchainos/dev-docs/home/api-access-and-usage
# Legacy OKLINK_API_KEY / OKLINK_SECRET_KEY / OKLINK_PASSPHRASE names are read as fallbacks.
OKXOS_API_KEY=
OKXOS_SECRET_KEY=
OKXOS_PASSPHRASE=

# DEMO_MODE=true bypasses x402 on paid routes (local only).
# Production paid ASP: set DEMO_MODE=false (or unset). Playground uses /api/playground/scan (free, rate limited).
DEMO_MODE=true

# OKX SA API credentials for x402 facilitator (required when DEMO_MODE is off)
# Docs: https://github.com/okx/payments/blob/master/typescript/SELLER.md
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Seller payee wallet on X Layer (eip155:196). Receives USDT0 per paid call.
# Primary name used by this app. PAY_TO is accepted as an alias (SELLER.md).
X402_PAYTO_ADDRESS=
PAY_TO=

# Optional: OKX facilitator base URL (default https://web3.okx.com)
OKX_FACILITATOR_BASE_URL=

# Public site URL (OG tags, llms.txt, origin checks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
